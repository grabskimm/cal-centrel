# AvailCal configuration — copy to .env and fill in. NEVER commit the real .env.
# Secrets in production live in Azure Key Vault; this file is for local/dev runs.

# --- Storage (output + raw device JSON) ---
# Blob container that holds /raw/*.json, /merged/availability.ics, /raw/*.ics
AVAILCAL_STORAGE_ACCOUNT=availcalstorage
AVAILCAL_BLOB_CONTAINER=availcal
# Optional explicit connection string (dev only). In cloud, Managed Identity is used.
# AZURE_STORAGE_CONNECTION_STRING=

# --- Key Vault (optional; cloud reads secrets from here at runtime) ---
# When set, ICS feed URLs / CalDAV passwords are read from Key Vault instead of env.
# AVAILCAL_KEYVAULT_URI=https://availcal-kv.vault.azure.net/

# --- Source registry ---
# Path to sources.toml mapping each raw input to its single-word label.
AVAILCAL_SOURCES_TOML=./sources.example.toml

# --- Secret ICS feed URLs (Google secret-iCal, Outlook published ICS, ...) ---
# Comma-separated list of "rawname=url" pairs. rawname must match a key in sources.toml.
# Example:
# AVAILCAL_ICS_FEEDS=GoogPersonal=https://calendar.google.com/.../basic.ics,OutlookPub=https://outlook.office365.com/.../calendar.ics
AVAILCAL_ICS_FEEDS=

# --- CalDAV via vdirsyncer ---
# Path to a vdirsyncer config; vdirsyncer syncs into AVAILCAL_VDIR_PATH which is then read.
AVAILCAL_VDIRSYNCER_CONFIG=./merge/vdirsyncer/config
AVAILCAL_VDIR_PATH=./vdir
# vdirsyncer is only invoked when AVAILCAL_ENABLE_CALDAV=1
AVAILCAL_ENABLE_CALDAV=0

# --- Merge / emit behaviour ---
# Expansion horizon in days from "now".
AVAILCAL_HORIZON_DAYS=90
# Treat tentative events as busy (true) or drop them (false).
AVAILCAL_INCLUDE_TENTATIVE=true
# Timezone used for all-day / floating events that carry no TZID.
AVAILCAL_DEFAULT_TZ=America/New_York
# Also emit one ICS per source under /raw/<label>.ics for color-coded overlays.
AVAILCAL_EMIT_PER_SOURCE=true

# --- Agent upload (Windows / macOS) ---
# Write-scoped SAS URL for the agent's own blob path (fallback when no Arc MI).
# Example: https://acct.blob.core.windows.net/availcal/raw/WorkX.json?sv=...&sig=...
AVAILCAL_AGENT_SAS_URL=
